#!/usr/bin/env zsh

# Telegram Bot API helper
# Usage:
#   tg getWebhookInfo <bot_token>
#   tg setWebhook <bot_token> <url>
#   tg sendMessage <bot_token> <chat_id> <text>

API_BASE="https://api.telegram.org"

if [[ $# -lt 2 ]]; then
  echo "Usage:"
  echo "  tg getWebhookInfo <bot_token>"
  echo "  tg setWebhook <bot_token> <url>"
  echo "  tg sendMessage <bot_token> <chat_id> <text>"
  exit 1
fi

cmd=$1
token=$2

case "$cmd" in
  getMe)
    curl -s "${API_BASE}/bot${token}/getMe" | jq .
    ;;
  getWebhookInfo)
    curl -s "${API_BASE}/bot${token}/getWebhookInfo" | jq .
    ;;
  setWebhook)
    if [[ $# -ne 3 ]]; then
      echo "Usage: tg setWebhook <bot_token> <url>"
      exit 1
    fi
    url=$3
    curl -s -X POST "${API_BASE}/bot${token}/setWebhook" \
      -d "url=${url}" | jq .
    ;;
  sendMessage)
    if [[ $# -ne 4 ]]; then
      echo "Usage: tg sendMessage <bot_token> <chat_id> <text>"
      exit 1
    fi
    chat_id=$3
    text=$4
    curl -s -X POST "${API_BASE}/bot${token}/sendMessage" \
      -d "chat_id=${chat_id}" \
      -d "text=${text}" \
      -d "parse_mode=Markdown" | jq .
    ;;
  *)
    echo "Unknown command: $cmd"
    echo "Available commands: getMe, getWebhookInfo, setWebhook, sendMessage"
    exit 1
    ;;
esac

